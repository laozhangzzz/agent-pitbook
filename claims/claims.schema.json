{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-pitbook.example/schema/claim.schema.json",
  "title": "Agent Pitbook Claim",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "pit_id",
    "claim",
    "status",
    "source_ids",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^claim-[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "pit_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "claim": {
      "type": "string",
      "minLength": 12
    },
    "status": {
      "type": "string",
      "enum": ["candidate", "supported", "disputed", "stale", "superseded"]
    },
    "source_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "supersedes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "contradicts": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "created_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "updated_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "notes": {
      "type": "string"
    }
  }
}

