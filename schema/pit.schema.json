{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/laozhangzzz/agent-pitbook/main/schema/pit.schema.json",
  "title": "Agent Pitbook Pit Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "summary",
    "status",
    "confidence",
    "created_at",
    "updated_at",
    "tags",
    "affected_tools",
    "symptoms",
    "environment",
    "root_cause",
    "fix",
    "verification",
    "source_links"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "title": {
      "type": "string",
      "minLength": 8
    },
    "summary": {
      "type": "string",
      "minLength": 20
    },
    "status": {
      "type": "string",
      "enum": ["candidate", "verified", "stale", "disputed"]
    },
    "confidence": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "created_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "updated_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "last_verified": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]*$"
      },
      "uniqueItems": true
    },
    "affected_tools": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]*$"
      },
      "uniqueItems": true
    },
    "symptoms": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "os": { "type": "string" },
        "arch": { "type": "string" },
        "shell": { "type": "string" },
        "language": { "type": "string" },
        "runtime": { "type": "string" },
        "package_manager": { "type": "string" },
        "framework": { "type": "string" },
        "agent": { "type": "string" },
        "versions": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "constraints": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "root_cause": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 8
      }
    },
    "fix": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["step"],
        "properties": {
          "step": { "type": "string", "minLength": 5 },
          "command": { "type": "string" },
          "rationale": { "type": "string" },
          "files": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "verification": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["method"],
        "properties": {
          "method": { "type": "string", "minLength": 5 },
          "command": { "type": "string" },
          "expected": { "type": "string" },
          "observed": { "type": "string" }
        }
      }
    },
    "workarounds": {
      "type": "array",
      "items": { "type": "string" }
    },
    "anti_patterns": {
      "type": "array",
      "items": { "type": "string" }
    },
    "source_links": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title", "type"],
        "properties": {
          "title": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["docs", "issue", "pr", "blog", "local-session", "release-note", "source-code", "other"]
          },
          "url": { "type": "string" },
          "locator": { "type": "string" },
          "accessed_at": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          }
        },
        "anyOf": [
          { "required": ["url"] },
          { "required": ["locator"] }
        ]
      }
    },
    "related": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      },
      "uniqueItems": true
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "external_text_trusted": { "type": "boolean" },
        "requires_confirmation": { "type": "boolean" },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
